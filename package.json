{
  "name": "@jozeuZz/alltura-ui",
  "version": "1.1.3",
  "description": "Alltura shared UI — layout, auth, notifications, tour",
  "main": "./dist/alltura-ui.mjs",
  "module": "./dist/alltura-ui.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/alltura-ui.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^11.0.4",
    "jwt-decode": "^4.0.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.8"
  }
}
